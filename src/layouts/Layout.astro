---
import Topbar from '../components/Topbar';
import '../styles/globals.css';

export interface Props {
	title: string;
	showTopbar?: boolean;
}

const { title, showTopbar = true } = Astro.props;

// Get user from middleware (will be null if not authenticated)
const user = Astro.locals.user;
---

<!doctype html>
<html lang="pl">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="10xCards - AI-powered flashcard generator" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script is:inline>
			(function(){
				const t = localStorage.getItem('theme');
				if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
					document.documentElement.classList.add('dark');
				}
			})();
		</script>
	</head>
	<body class="min-h-screen bg-background text-foreground">
		{showTopbar && <Topbar client:load user={user} />}
		<slot />
	</body>
</html>
